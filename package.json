{
  "name": "reciproca",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:matching": "tsx --test src/lib/matching/matching.test.ts src/lib/matching/matching-quality.test.ts src/lib/matching/score-quantity.test.ts src/lib/matching/embeddings/cosine.test.ts",
    "test:trades": "tsx --test src/lib/trades/trades.test.ts",
    "mock:backend": "node scripts/mock-backend.mjs",
    "test:onboarding": "node scripts/test-onboarding-flow.mjs",
    "db:start": "supabase start",
    "db:reset": "supabase db reset && node scripts/seed-random-businesses.mjs",
    "db:seed": "npm run db:reset",
    "db:seed:businesses": "node scripts/seed-random-businesses.mjs",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/lib/db/database.generated.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@supabase/supabase-js": "^2.107.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "svix": "^1.95.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "pg": "^8.21.0",
    "supabase": "^2.105.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
