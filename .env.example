# Reciproca — copy to .env.local at the repo root (never commit .env.local)
# Deployment guide: docs/DEPLOYMENT.md

# ── Vercel (Next.js web app) ────────────────────────────────────────────────

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Onboarding backend — Render URL in prod; http://localhost:3001 for local mock
BACKEND_API_URL=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Remote schema setup (npm run db:setup:remote) — one of:
# SUPABASE_ACCESS_TOKEN=   # Account → Access Tokens (sbp_…)
# SUPABASE_DB_PASSWORD=    # Project Settings → Database
# SUPABASE_DB_HOST=aws-1-us-west-2.pooler.supabase.com  # if pooler (optional)
# DATABASE_URL=            # Full Postgres connection string

# OpenAI — embeddings for listing semantic match (optional; falls back to rules)
OPENAI_API_KEY=

# App — production: https://<your-app>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Render (services/onboarding-api) — set in Render dashboard, not Vercel ──
# SUPABASE_URL=https://<project-ref>.supabase.co   # REQUIRED (or NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY= # server only
# CLERK_SECRET_KEY=          # same as Vercel
# ALLOWED_ORIGINS=           # optional: https://<your-app>.vercel.app
# PORT=                      # set by Render automatically
